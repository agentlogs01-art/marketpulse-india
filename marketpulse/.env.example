# .env.example
#
# Copy to .env for local development (never commit the real .env).
# In production, these are set as GitHub Actions repo secrets / Railway
# environment variables -- never hardcoded in source.

# --- Supabase (persistence layer) -------------------------------------
# Project Settings -> API in the Supabase dashboard.
# Use the SERVICE ROLE key here, never the anon/public key -- this code
# runs server-side only and relies on bypassing RLS (see persistence/schema.sql).
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Gemini (AI sentiment/sector analysis, FR-02.2) --------------------
GEMINI_API_KEY=your-gemini-api-key

# --- SMTP (email dispatch + transactional verification emails) ---------
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASSWORD=your-smtp-password
EMAIL_FROM_ADDRESS=briefing@marketpulseindia.app

# --- Subscriber fallback (used only if Supabase is unreachable/unset) --
SUBSCRIBER_LIST=you@example.com,teammate@example.com

# --- WhatsApp delivery (Twilio) -----------------------------------------
# Sandbox is free for development -- https://www.twilio.com/console/sms/whatsapp/sandbox
# Production requires WhatsApp Business Platform approval via Meta.
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --- Telegram delivery (Bot API, fully free) -----------------------------
# Create a bot via @BotFather in Telegram, then set its webhook to:
#   https://api.telegram.org/bot<TOKEN>/setWebhook?url=<your-deployed-url>/api/telegram/webhook
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_BOT_USERNAME=MarketPulseIndiaBot

# --- Web app / API (api/app.py) ------------------------------------------
# Base URL the verification email's link points to -- must match wherever
# webapp/index.html is actually deployed/served from.
WEBAPP_BASE_URL=https://marketpulseindia.app
PORT=8000

# --- Auth note -------------------------------------------------------------
# No separate secret is needed for sign-in: passwords are hashed locally
# (werkzeug, scrypt) before ever reaching Supabase, and session tokens are
# opaque random strings stored in the `sessions` table (see persistence/
# schema.sql) -- not JWTs, so there's no signing key to configure here.
